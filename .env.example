# Copy this file to `.env.local` and fill in your Supabase project values,
# then restart `npm run dev`.
#   Supabase dashboard → Project Settings → API
#     • Project URL                  → NEXT_PUBLIC_SUPABASE_URL
#     • Project API keys: anon/public → NEXT_PUBLIC_SUPABASE_ANON_KEY
# The anon key is safe to expose in the browser. Never commit the service_role key.
# While these are empty, the app falls back to a front-end mock login.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# After setting the keys above, configure Supabase Auth so redirects resolve:
#   Supabase dashboard → Authentication → URL Configuration
#     • Site URL            → http://localhost:3000   (your deployed origin in prod)
#     • Additional Redirect → http://localhost:3000/auth/callback
#                             https://<your-domain>/auth/callback
# Then run supabase/schema.sql in the SQL editor to create the tables + RLS.

# ─────────────────────────────────────────────────────────────────────────────
# Razorpay payments (optional) — gate the paid plans (Family+ ₹99, Community ₹499)
# behind a real checkout. Until both are set, those plans show "Payment
# unavailable" and only the free JAN plan can be switched. Use TEST keys for
# test mode (no real money): Razorpay dashboard → Settings → API Keys.
#   • Key Id     (browser-safe) → NEXT_PUBLIC_RAZORPAY_KEY_ID
#   • Key Secret (server only)  → RAZORPAY_KEY_SECRET   (never expose / commit)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# AI features (optional, FREE) — powers the symptom checker, the "Mitra"
# wellness chat, the AI history builder and the plain-language explanations of
# uploaded health records. Until a key is set, these still load but return a
# friendly "AI isn't enabled yet" message instead of crashing.
#
# PREFERRED — Groq (free, fast, no credit card): https://console.groq.com/keys
#   • API key (server only) → GROQ_API_KEY        (never expose / commit)
#   • Optional: GROQ_MODEL          (default: llama-3.3-70b-versatile)
#   • Optional: GROQ_VISION_MODEL   (default: meta-llama/llama-4-scout-17b-16e-instruct)
#
# OPTIONAL — Gemini, only needed to analyze PDF record scans (Groq vision reads
# images but not PDFs). Free key: https://aistudio.google.com/apikey
#   • GEMINI_API_KEY (server only) · optional GEMINI_MODEL (default gemini-1.5-flash)
#
# If both are set, text tools use Groq; PDF record-scans fall back to Gemini.
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
